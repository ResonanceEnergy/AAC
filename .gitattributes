# Auto detect text files and normalise to LF
* text=auto eol=lf

# Force LF for shell scripts
*.sh text eol=lf

# Force CRLF for Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.db binary
*.sqlite binary
*.sqlite3 binary
