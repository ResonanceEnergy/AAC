# -----------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AAC:v1.0.0 (by /u/your_username)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# -----------------------------------------------
# AI / LLM API KEYS
# -----------------------------------------------

# Anthropic Claude (primary LLM)
ANTHROPIC_API_KEY=

# Google Gemini (research agent)
GOOGLE_AI_API_KEY=

# OpenAI GPT (fallback)
OPENAI_API_KEY=

# xAI Grok
XAI_API_KEY=

# -----------------------------------------------
# OPENCLAW / BARREN WUFFET / CLAWHUB
# -----------------------------------------------
# OpenClaw workspace (default: ~/.openclaw/workspace/skills/)
OPENCLAW_SKILLS_DIR=
# OpenClaw Gateway WebSocket URL
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OpenClaw Gateway auth token
OPENCLAW_GATEWAY_TOKEN=
