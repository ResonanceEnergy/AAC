# =============================================================
# AAC — Accelerated Arbitrage Corp
# Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.template .env
#
# NEVER commit .env to git — it is gitignored.
# Run: python scripts/configure_api_keys.py  to guide setup.
# Run: python scripts/setup_production.py    for full setup.
# =============================================================

# -----------------------------------------------
# MASTER SECRETS ENCRYPTION PASSWORD
# Generated automatically by setup_production.py
# -----------------------------------------------
ACC_MASTER_PASSWORD=

# -----------------------------------------------
# ENVIRONMENT
# -----------------------------------------------
AAC_ENV=development
# Options: development | paper | production
PAPER_TRADING=true
LIVE_TRADING_ENABLED=false
DRY_RUN=true
# LIVE_TRADING_CONFIRMATION=YES_I_UNDERSTAND  # Required for live trading

# -----------------------------------------------
# EXCHANGE API KEYS
# -----------------------------------------------

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Coinbase Pro
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSPHRASE=

# Kraken
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Interactive Brokers (IBKR)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=
IBKR_PAPER=true

# Moomoo / Futu (requires OpenD gateway running)
# Download OpenD: https://www.moomoo.com/download/OpenD
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_ENV=SIMULATE
MOOMOO_MARKET=US
MOOMOO_SECURITY_FIRM=FUTUINC
MOOMOO_TRADE_PASSWORD=
MOOMOO_ENABLED=false

# NDAX — National Digital Asset Exchange (Canadian crypto)
# https://ndax.io
NDAX_API_KEY=
NDAX_API_SECRET=
NDAX_USER_ID=
NDAX_TESTNET=true

# -----------------------------------------------
# EQ BANK — Funding Source (Canadian digital bank)
# -----------------------------------------------
EQ_BANK_ENABLED=false
EQ_BANK_ACCOUNT_LABEL=EQ Bank Savings Plus
EQ_BANK_LINKED_BROKERS=ibkr,moomoo,ndax

# -----------------------------------------------
# MARKET DATA APIS — FREE TIER (no key required)
# -----------------------------------------------
# ECB (European Central Bank) — free, no key
# World Bank Data Catalog — free, no key
# Yahoo Finance (yfinance) — free, no key

# -----------------------------------------------
# MARKET DATA APIS — PREMIUM (key required)
# -----------------------------------------------

# CoinGecko — https://www.coingecko.com (required for crypto pipeline)
COINGECKO_API_KEY=

# Polygon.io — https://polygon.io
POLYGON_API_KEY=

# Finnhub — https://finnhub.io
FINNHUB_API_KEY=

# Alpha Vantage — https://www.alphavantage.co
ALPHAVANTAGE_API_KEY=

# Twelve Data — https://twelvedata.com
TWELVE_DATA_API_KEY=

# IEX Cloud — https://iexcloud.io
IEX_CLOUD_API_KEY=

# EODHD — https://eodhd.com
EODHD_API_KEY=

# Intrinio — https://intrinio.com
INTRINIO_API_KEY=
INTRINIO_USERNAME=

# FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org
FRED_API_KEY=

# TradeStie Reddit Sentiment — https://tradestie.com
TRADESTIE_API_KEY=

# WallStreetOdds — https://wallstreetodds.com
WALLSTREETODDS_API_KEY=

# Unusual Whales — https://unusualwhales.com/public-api/mcp
# Market intelligence: options flow, dark pool, congress trades, filings
UNUSUAL_WHALES_API_KEY=
# Safer local alternative: keep the raw key in an ignored file such as
# secrets/unusual_whales_api_key.txt and point this variable at it.
UNUSUAL_WHALES_API_KEY_FILE=

# -----------------------------------------------
# AI / LLM APIS
# -----------------------------------------------

# xAI Grok — https://x.ai
XAI_API_KEY=

# OpenAI (optional) — https://platform.openai.com
OPENAI_API_KEY=

