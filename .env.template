# Funder address (the address that holds your USDC on Polymarket)
POLYMARKET_FUNDER_ADDRESS=
# Chain ID (137 = Polygon mainnet)
POLYMARKET_CHAIN_ID=137

# -----------------------------------------------
# NOTIFICATIONS / ALERTS
# -----------------------------------------------

# Telegram — create bot via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack — create webhook in Slack settings
SLACK_WEBHOOK_URL=

# Email (SMTP) — configure for email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# -----------------------------------------------
# MESSAGING — KAFKA
# -----------------------------------------------
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_TRADES=aac.trades
KAFKA_TOPIC_SIGNALS=aac.signals
KAFKA_TOPIC_ALERTS=aac.alerts
KAFKA_GROUP_ID=aac-consumer-group

# -----------------------------------------------
# CACHING — REDIS
# -----------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# -----------------------------------------------
# DATABASE
# -----------------------------------------------
