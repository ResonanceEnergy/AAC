# =============================================================
# AAC — Accelerated Arbitrage Corp
# Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it is gitignored.
# Run: python scripts/configure_api_keys.py  to guide setup.
# Run: python scripts/setup_production.py    for full setup.
# =============================================================

# -----------------------------------------------
# MASTER SECRETS ENCRYPTION PASSWORD
# Generated automatically by setup_production.py
# -----------------------------------------------
ACC_MASTER_PASSWORD=

# -----------------------------------------------
# ENVIRONMENT
# -----------------------------------------------
AAC_ENV=development
# Options: development | paper | production
PAPER_TRADING=true
LIVE_TRADING_ENABLED=false
DRY_RUN=true
# LIVE_TRADING_CONFIRMATION=YES_I_UNDERSTAND  # Required for live trading

# -----------------------------------------------
# EXCHANGE API KEYS
# -----------------------------------------------

# Binance (deprioritized — crypto via NDAX)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Coinbase Pro (deprioritized)
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSPHRASE=

# Kraken (deprioritized)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Interactive Brokers (IBKR) — PRIMARY for stocks, ETFs, futures
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=
IBKR_PAPER=true

# NDAX — PRIMARY for crypto trading (Canadian exchange)
NDAX_API_KEY=
NDAX_API_SECRET=
NDAX_USER_ID=
NDAX_ACCOUNT_ID=

# Moomoo/FUTU — Gateway Configuration (socket-based)
MOOMOO_HOST=127.0.0.1
MOOMOO_PORT=11111
MOOMOO_TRADE_ENV=SIMULATE
MOOMOO_MARKET=US
MOOMOO_SECURITY_FIRM=FUTUINC
MOOMOO_TRADE_PASSWORD=
MOOMOO_ENABLED=false

# Noxi Rise / MetaTrader 5
MT5_PATH=
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=NoxiRise-Live

# -----------------------------------------------
# MARKET DATA APIS — FREE TIER (no key required)
# -----------------------------------------------
# ECB (European Central Bank) — free, no key
# World Bank Data Catalog — free, no key
# Yahoo Finance (yfinance) — free, no key
# Fear & Greed Index — no key required (Alternative.me)
# Google Trends (pytrends — no key, library-based)

# -----------------------------------------------
# FOREIGN EXCHANGE (Knightsbridge FX)
# https://www.knightsbridgefx.com
# Rate source: https://www.exchangerate-api.com (free 1500 req/mo)
# -----------------------------------------------
FX_API_KEY=
FX_SPREAD_BPS=50
FX_POLL_INTERVAL=60

# -----------------------------------------------
# MARKET DATA APIS — PREMIUM (key required)
# -----------------------------------------------

# CoinGecko — https://www.coingecko.com (required for crypto pipeline)
COINGECKO_API_KEY=

# Polygon.io — https://polygon.io
POLYGON_API_KEY=

# Finnhub — https://finnhub.io
FINNHUB_API_KEY=

# Alpha Vantage — https://www.alphavantage.co
ALPHAVANTAGE_API_KEY=

# Twelve Data — https://twelvedata.com
TWELVE_DATA_API_KEY=

# IEX Cloud — https://iexcloud.io
IEX_CLOUD_API_KEY=

# EODHD — https://eodhd.com
EODHD_API_KEY=

# Intrinio — https://intrinio.com
INTRINIO_API_KEY=

# TradeStie Reddit Sentiment — https://tradestie.com
TRADESTIE_API_KEY=

# WallStreetOdds — https://wallstreetodds.com
WALLSTREETODDS_API_KEY=

# Tradier — https://developer.tradier.com (free sandbox)
TRADIER_API_KEY=
TRADIER_SANDBOX=true

# FRED (Federal Reserve Economic Data) — free
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Whale Alert — https://docs.whale-alert.io (free tier)
WHALE_ALERT_API_KEY=

# Santiment — https://app.santiment.net (free tier)
SANTIMENT_API_KEY=

# -----------------------------------------------
# ALTERNATIVE DATA — HIGH-PRIORITY
# -----------------------------------------------

# Unusual Whales — https://unusualwhales.com/api
UNUSUAL_WHALES_API_KEY=
# Safer local alternative: keep the raw key in an ignored file such as
# secrets/unusual_whales_api_key.txt and point this variable at it.
UNUSUAL_WHALES_API_KEY_FILE=

# CoinMarketCap — https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=

# NewsAPI — https://newsapi.org
NEWS_API_KEY=

# -----------------------------------------------
# AI / LLM API KEYS
# -----------------------------------------------

# Anthropic Claude (primary LLM)
ANTHROPIC_API_KEY=

# Google Gemini (research agent)
GOOGLE_AI_API_KEY=

# OpenAI GPT (fallback)
OPENAI_API_KEY=

# xAI Grok — https://x.ai
XAI_API_KEY=

# -----------------------------------------------
# REDDIT API (PRAW — sentiment analysis)
# https://www.reddit.com/prefs/apps
# -----------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AAC:v1.0.0 (by /u/your_username)
REDDIT_USERNAME=
REDDIT_PASSWORD=

# -----------------------------------------------
# OPENCLAW / BARREN WUFFET / CLAWHUB
# -----------------------------------------------
OPENCLAW_SKILLS_DIR=
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_DAILY_SPEND_LIMIT=10.00
CLAWHUB_API_KEY=
AAC_API_KEY=

# -----------------------------------------------
# CRYPTO / WEB3
# -----------------------------------------------
ETHERSCAN_API_KEY=
INFURA_PROJECT_ID=
ETH_PRIVATE_KEY=
ETH_RPC_URL=
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# -----------------------------------------------
# METALLICUS ECOSYSTEM (Metal X / XPR Network / Metal Blockchain)
# -----------------------------------------------

# Metal X DEX — https://metalx.com
# Create WebAuth wallet at https://wauth.co/ then verify on Metal X
METALX_ACCOUNT_NAME=
METALX_PRIVATE_KEY=

# XPR Network — XPR Agents marketplace & on-chain operations
XPR_RPC_URL=
XPR_ACCOUNT_NAME=
XPR_PRIVATE_KEY=

# Metal Blockchain C-Chain (EVM compatible)
METAL_BLOCKCHAIN_RPC_URL=https://tahoe.metalblockchain.org/ext/bc/C/rpc

# Metal Pay B2B — fiat on/off ramp (NMLS #2057807)
METALPAY_API_KEY=
METALPAY_API_SECRET=

# WebAuth wallet integration — identity & signing
WEBAUTH_APP_ID=aac_trading
WEBAUTH_CALLBACK_URL=

# -----------------------------------------------
# NOTIFICATIONS / ALERTS
# -----------------------------------------------

# Telegram — create bot via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack — create webhook in Slack settings
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#trading-alerts

# Discord — Gasket server for trade confirmations
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
GASKET_CHANNEL_ID=

# Options Intelligence Pre-Market Scanner
PREMARKET_SCAN_HOUR=9
PREMARKET_SCAN_MINUTE=15
TRADE_CONFIRM_TIMEOUT_MINUTES=15
PREMARKET_MIN_SCORE=60
PREMARKET_STRONG_ONLY=false

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# -----------------------------------------------
# MESSAGING — KAFKA
# -----------------------------------------------
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_TRADES=aac.trades
KAFKA_TOPIC_SIGNALS=aac.signals
KAFKA_TOPIC_ALERTS=aac.alerts
KAFKA_GROUP_ID=aac-consumer-group

# -----------------------------------------------
# CACHING — REDIS
# -----------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# -----------------------------------------------
# DATABASE
# -----------------------------------------------
DATABASE_URL=sqlite:///data/aac.db
# For PostgreSQL: postgresql://user:password@localhost:5432/aac

# -----------------------------------------------
# TWITTER / X (for market sentiment)
# -----------------------------------------------
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# -----------------------------------------------
# DASHBOARD & API SERVER
# -----------------------------------------------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050
DASHBOARD_URL=http://localhost:3000
DASHBOARD_SECRET_KEY=
API_PORT=8000
DEBUG=false

# -----------------------------------------------
# RISK MANAGEMENT
# -----------------------------------------------
MAX_POSITION_SIZE_USD=10000
MAX_DAILY_LOSS_USD=1000
MAX_DRAWDOWN_PERCENT=0.05
DEFAULT_RISK_PERCENT=0.01
EMERGENCY_STOP_LOSS=0.10
MAX_OPEN_POSITIONS=10
STRATEGY_MAX_ALLOCATION_PCT=25
MAX_DAILY_TRADES=100
DRY_RUN=true

# -----------------------------------------------
# INTERNAL SERVICES
# -----------------------------------------------
BIGBRAIN_API_URL=http://localhost:8001/api/v1
BIGBRAIN_AUTH_TOKEN=
CRYPTO_INTEL_API_URL=http://localhost:8002/api/v1
ACCOUNTING_API_URL=http://localhost:8003/api/v1
NCC_COORDINATOR_ENDPOINT=http://localhost:8000/api/v1
NCC_AUTH_TOKEN=

# -----------------------------------------------
# KYC
# -----------------------------------------------
KYC_PROVIDER_API_KEY=
KYC_PROVIDER_URL=
