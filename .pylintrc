[MAIN]
load-plugins=
extension-pkg-whitelist=numpy,pandas

[MESSAGES CONTROL]
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    C0103,  # invalid-name (short variable names common in trading)
    C0209,  # consider-using-f-string
    C0301,  # line-too-long
    C0302,  # too-many-lines
    C0303,  # trailing-whitespace
    C0304,  # missing-final-newline
    C0411,  # wrong-import-order
    C0413,  # wrong-import-position
    C0415,  # import-outside-toplevel
    R0801,  # duplicate-code
    R0901,  # too-many-ancestors
    R0902,  # too-many-instance-attributes
    R0903,  # too-few-public-methods
    R0904,  # too-many-public-methods
    R0911,  # too-many-return-statements
    R0912,  # too-many-branches
    R0913,  # too-many-arguments
    R0914,  # too-many-locals
    R0915,  # too-many-statements
    R1702,  # too-many-nested-blocks
    R1710,  # inconsistent-return-statements
    W0107,  # unnecessary-pass
    W0201,  # attribute-defined-outside-init
    W0212,  # protected-access
    W0221,  # arguments-differ
    W0223,  # abstract-method
    W0231,  # super-init-not-called
    W0237,  # arguments-renamed
    W0401,  # wildcard-import
    W0511,  # fixme/todo
    W0603,  # global-statement
    W0611,  # unused-import
    W0612,  # unused-variable
    W0613,  # unused-argument
    W0621,  # redefined-outer-name
    W0622,  # redefined-builtin
    W0640,  # cell-var-from-loop
    W0703,  # broad-except (old code)
    W0718,  # broad-exception-caught
    W0719,  # broad-exception-raised
    W1203,  # logging-fstring-interpolation
    W1514,  # unspecified-encoding
    E0401,  # import-error (many optional deps)
    E0611,  # no-name-in-module
    E1101,  # no-member (too many false positives with dynamic attrs)
    E1136,  # unsubscriptable-object

[FORMAT]
max-line-length=120

[TYPECHECK]
ignored-modules=numpy,pandas,aiohttp,websockets,ib_insync,moomoo
ignored-classes=optparse.Values,thread._local,_thread._local

[SIMILARITIES]
min-similarity-lines=8
ignore-imports=yes

[DESIGN]
max-args=15
max-locals=30
max-returns=10
max-branches=20
max-statements=100
max-attributes=30
